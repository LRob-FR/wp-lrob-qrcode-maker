#. Plugin Name of the plugin
msgid "LRob - QR Code Maker"
msgstr "LRob - QR Code Maker"

#. Plugin URI of the plugin
msgid "https://www.lrob.fr/wordpress/plugins/lrob-qrcode-maker/"
msgstr "https://www.lrob.fr/wordpress/plugins/lrob-qrcode-maker/"

#. Description of the plugin
msgid ""
"Customizable QR codes for WordPress — public Gutenberg block for visitors to "
"create and download their own, admin library with optional scan tracking. "
"Browser-side rendering, no server round-trip. Logos picked from the Media "
"Library (admin) or kept in the visitor's browser only (public block)."
msgstr ""
"QR codes personnalisables pour WordPress — bloc Gutenberg public pour que "
"vos visiteurs créent et téléchargent les leurs, bibliothèque admin avec "
"suivi des scans optionnel. Rendu côté navigateur, sans aller-retour serveur. "
"Logos choisis dans la médiathèque (admin) ou conservés uniquement dans le "
"navigateur du visiteur (bloc public)."

#. Author of the plugin
msgid "LRob"
msgstr "LRob"

#. Author URI of the plugin
msgid "https://www.lrob.fr"
msgstr "https://www.lrob.fr"

