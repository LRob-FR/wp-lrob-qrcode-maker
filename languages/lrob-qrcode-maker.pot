#: src/Admin/LibraryPage.php:206
#: src/Block/Maker.php:175
msgid "What the QR encodes. Each type composes the correct payload format: URL, vCard 3.0 contact, Wi-Fi credentials, mailto:, SMS, tel:, geo:, plain text."
msgstr ""

#: src/Admin/LibraryPage.php:224
msgid "Replaces the encoded payload with a short /qr/{slug} URL that redirects to your target. Lets you change the destination after the QR has been printed, and counts scans per QR. Recommended for vCards with accents — works around scanner bugs by serving a .vcf file."
msgstr ""

#. translators: %s: tracking URL prefix, e.g. /qr
#: src/Admin/LibraryPage.php:233
msgid "Use a short %s URL and count scans"
msgstr ""

#: src/Admin/LibraryPage.php:240
msgid "Will resolve to"
msgstr ""

#: src/Admin/LibraryPage.php:244
msgid "Tracking is only available for URL, plain text, and vCard content. Wi-Fi, email, SMS, Tel and Geo encode native schemes that scanners act on directly — an HTTP redirect would break the QR."
msgstr ""

#: src/Admin/LibraryPage.php:248
#: src/Block/Maker.php:135
msgid "Design"
msgstr ""

#: src/Admin/LibraryPage.php:258
#: src/Admin/LibraryPage.php:261
#: src/Block/Maker.php:121
#: assets/js/block-editor.js:136
msgid "Foreground"
msgstr ""

#: src/Admin/LibraryPage.php:259
#: src/Block/Maker.php:176
msgid "Color of the QR modules (the dark squares that encode data). High contrast vs the background is critical — pure black is the most reliable."
msgstr ""

#: src/Admin/LibraryPage.php:265
#: src/Admin/LibraryPage.php:268
#: src/Block/Maker.php:122
#: assets/js/block-editor.js:137
msgid "Background"
msgstr ""

#: src/Admin/LibraryPage.php:266
#: src/Block/Maker.php:177
msgid "Color behind the modules. White or very light is best; coloured backgrounds reduce contrast and can break scanning on cheap phones."
msgstr ""

#: src/Admin/LibraryPage.php:272
#: src/Admin/LibraryPage.php:275
#: src/Block/Maker.php:123
#: assets/js/block-editor.js:138
msgid "Eye color"
msgstr ""

#: src/Admin/LibraryPage.php:273
#: src/Block/Maker.php:178
msgid "Color of the three big corner finder patterns. Usually matches the foreground; a different color is decorative but should still contrast strongly with the background."
msgstr ""

#: src/Admin/LibraryPage.php:280
#: src/Block/Maker.php:124
msgid "Transparent background"
msgstr ""

#: src/Admin/LibraryPage.php:281
#: src/Block/Maker.php:179
msgid "Drops the background fill so the underlying page or photo shows through. The QR scans only if the surface behind it is uniform and light — patterned or dark backgrounds will break it."
msgstr ""

#: src/Admin/LibraryPage.php:288
#: src/Block/Maker.php:125
msgid "Dot shape"
msgstr ""

#: src/Admin/LibraryPage.php:289
#: src/Block/Maker.php:180
msgid "Visual style of the data modules. Square is the most scannable; rounded and classy shapes look softer but slightly reduce module-edge contrast."
msgstr ""

#: src/Admin/LibraryPage.php:304
#: src/Block/Maker.php:126
#: assets/js/block-editor.js:140
msgid "Eye shape"
msgstr ""

#: src/Admin/LibraryPage.php:305
#: src/Block/Maker.php:181
msgid "Visual style of the three big corner patterns. Square is the standard QR look; the others are decorative variations on the same finder geometry."
msgstr ""

#: src/Admin/LibraryPage.php:321
#: src/Admin/LibraryPage.php:326
#: src/Block/Maker.php:172
msgid "Error correction"
msgstr ""

#: src/Admin/LibraryPage.php:322
#: src/Block/Maker.php:173
msgid "Lets scanners read the QR even if it’s partly damaged or covered by a logo. Higher levels tolerate more damage but make the QR denser. Auto picks the best level for your case."
msgstr ""

#: src/Admin/LibraryPage.php:328
#: src/Block/Maker.php:184
msgid "Auto"
msgstr ""

#: src/Admin/LibraryPage.php:328
msgid "Picks the best level for your case: highest EC that doesn’t enlarge the QR if no logo, biggest possible logo if one is attached."
msgstr ""

#: src/Admin/LibraryPage.php:329
#: src/Block/Maker.php:185
msgid "Min"
msgstr ""

#: src/Admin/LibraryPage.php:329
msgid "Level L · 7% damage recovery. Smallest, densest QR — fragile if printed small or scanned at an angle. Use for short URLs in ideal conditions."
msgstr ""

#: src/Admin/LibraryPage.php:330
#: src/Block/Maker.php:186
msgid "Low"
msgstr ""

#: src/Admin/LibraryPage.php:330
msgid "Level M · 15% damage recovery. Slightly bigger QR. Solid default for screen display and clean prints."
msgstr ""

#: src/Admin/LibraryPage.php:331
#: src/Admin/LibraryPage.php:373
#: src/Block/Maker.php:170
#: src/Block/Maker.php:187
msgid "Medium"
msgstr ""

#: src/Admin/LibraryPage.php:331
msgid "Level Q · 25% damage recovery. Tolerates moderate dirt, glare or partial logo overlap. Good for print on uncoated paper."
msgstr ""

#: src/Admin/LibraryPage.php:332
#: src/Block/Maker.php:188
msgid "High"
msgstr ""

#: src/Admin/LibraryPage.php:332
msgid "Level H · 30% damage recovery. Biggest QR for the same data, most robust, allows the largest logo. Use for outdoor or rough-environment prints."
msgstr ""

#: src/Admin/LibraryPage.php:343
#: src/Block/Maker.php:136
msgid "Logo"
msgstr ""

#: src/Admin/LibraryPage.php:344
msgid "Overlay an image at the QR’s center — a logo, mascot, etc. The chosen Error correction level determines how much of the QR can be safely covered. The image is stored with the QR card and reused on every export."
msgstr ""

